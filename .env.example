# =============================================================================
# DOMAINS
# =============================================================================
SUB_DOMAIN=rag
SERVER_DOMAIN=example.com

# =============================================================================
# NEXTCLOUD WEBDAV
# =============================================================================
NEXTCLOUD_URL=https://nextcloud.example.com
NEXTCLOUD_USER=your_username
NEXTCLOUD_APP_PASSWORD=your_app_password
NEXTCLOUD_MCP_API_KEY=generate_with_python3_-c_"import_secrets;_print(secrets.token_urlsafe(32))"

# =============================================================================
# QDRANT
# =============================================================================
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=pdf_library

# =============================================================================
# EMBEDDINGS
# =============================================================================
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# =============================================================================
# MCP AUTH
# =============================================================================
MCP_BEARER_TOKEN=generate_with_python3_-c_"import_secrets;_print(secrets.token_urlsafe(32))"

# =============================================================================
# PAPERCLIP
# =============================================================================
BETTER_AUTH_SECRET=generate_with_python3_-c_"import_secrets;_print(secrets.token_hex(32))"
PAPERCLIP_SUB_DOMAIN=paperclip

# =============================================================================
# OUTLINE
# =============================================================================
OUTLINE_URL=https://outline.collaborationism.tech
OUTLINE_API_KEY=ol_api_your_key_here
OUTLINE_SYNC_INTERVAL=300
OUTLINE_QDRANT_COLLECTION=outline_docs

# =============================================================================
# OUTLINE PER-AGENT AUTH (hermes-gateway)
# =============================================================================
# OUTLINE_DB_URL=postgres://outline:password@outline-postgres:5432/outline
